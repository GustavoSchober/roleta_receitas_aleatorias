model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  recipes       Recipe[]
  sectors       Sector[]
}

model Recipe {
  id          String   @id @default(cuid())
  name        String
  ingredients String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Sector {
  id         String   @id @default(cuid())
  type       String   
  recipeIds  String[] 
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}